<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme — edge to edge, true black -->
    <style name="Theme.FocusPhone" parent="android:Theme.Material.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>

    <!-- Transparent theme for MindfulDelayActivity overlay -->
    <style name="Theme.Transparent" parent="android:Theme.Material.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>

</resources>
